PORT=5001
NODE_ENV=development

# MongoDB (leave empty for local dev with memory server)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/freshmarket?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# CORS
ALLOWED_ORIGIN=https://your-frontend-domain.onrender.com
FRONTEND_URL=https://your-frontend-domain.onrender.com

# Admin Account Credentials
ADMIN_EMAIL=admin@freshmarket.com
ADMIN_PASSWORD=SecureAdminPassword123!
ADMIN_NAME=Admin

# Email / SMTP Configuration
# For Gmail: Enable 2-Step Verification, then create an App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
FROM_NAME=FreshMarket

# Cloudinary (optional, for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
